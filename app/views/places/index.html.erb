<% query = params[:query].to_s.strip %>
<% search_active = query.present? %>
<% portuguese = I18n.locale.to_s == "pt-BR" %>
<% result_count = @places.size %>
<% detail_params = search_active ? { query: query } : {} %>
<% safe_count = @places.count { |place| place.status == "positive" } %>
<% alert_count = @places.count { |place| place.status == "neutral" } %>
<% avoid_count = @places.count { |place| place.status == "negative" } %>

<div class="search-results-page">
  <div class="search-results-container"
       data-controller="map"
       data-mapbox-key="<%= ENV['MAPBOX_API_KEY'] %>"
       data-markers="<%= @markers.to_json %>"
       data-action="search:placeSelected@window->map#zoomToPlace">

    <div class="places-list-column">
      <section class="places-search-shell">
        <div class="places-search-intro">
          <span class="places-eyebrow"><%= portuguese ? "Explorar lugares" : "Explore places" %></span>

          <% if search_active %>
            <% header_text = portuguese ? "Resultados para “#{query}”" : "Results for “#{query}”" %>
            <% results_text =
                 if result_count.zero?
                   portuguese ? "Nenhum local encontrado." : "No places found."
                 elsif result_count == 1
                   portuguese ? "1 local encontrado." : "1 place found."
                 else
                   portuguese ? "#{result_count} locais encontrados." : "#{result_count} places found."
                 end %>

            <h1><%= header_text %></h1>
            <p><%= results_text %></p>
          <% else %>
            <h1><%= portuguese ? "Decida com mais contexto antes de ir" : "Decide with more context before you go" %></h1>
            <p><%= portuguese ? "Pesquise um lugar, revise o sinal atual e compare rapidamente os locais no mapa." : "Search for a place, review the current signal, and compare locations quickly on the map." %></p>
          <% end %>
        </div>

        <%= render "shared/search_bar" %>

        <div class="places-signal-strip">
          <div class="places-signal-chip places-signal-chip--positive">
            <strong><%= safe_count %></strong>
            <span><%= portuguese ? "seguros" : "safe" %></span>
          </div>

          <div class="places-signal-chip places-signal-chip--neutral">
            <strong><%= alert_count %></strong>
            <span><%= portuguese ? "atenção" : "attention" %></span>
          </div>

          <div class="places-signal-chip places-signal-chip--negative">
            <strong><%= avoid_count %></strong>
            <span><%= portuguese ? "evitar" : "avoid" %></span>
          </div>
        </div>
      </section>

      <div class="places-list">
        <% if @places.any? %>
          <% @places.each do |place| %>
            <% status_key = place.status %>
            <% status_label =
                 case status_key
                 when "positive" then (portuguese ? "Seguro" : "Safe")
                 when "negative" then (portuguese ? "Evitar" : "Avoid")
                 else
                   portuguese ? "Atenção" : "Attention"
                 end %>
            <% report_count = place.reports.size %>
            <% report_text =
                 if portuguese
                   report_count == 1 ? "1 relato" : "#{report_count} relatos"
                 else
                   report_count == 1 ? "1 report" : "#{report_count} reports"
                 end %>

            <article class="place-card place-card--<%= status_key %>"
                     data-action="click->map#flyTo"
                     data-lat="<%= place.latitude %>"
                     data-lng="<%= place.longitude %>"
                     data-place-id="<%= place.id %>">
              <div class="place-card-top">
                <div class="place-card-copy">
                  <div class="place-card-header">
                    <h2><%= place.name %></h2>
                    <span class="place-status"><%= status_label %></span>
                  </div>

                  <p class="place-address"><%= place.address %></p>
                </div>

                <div class="place-card-meta">
                  <span class="place-report-count"><%= report_text %></span>
                </div>
              </div>

              <div class="place-card-bottom">
                <p class="place-card-helper">
                  <%= if status_key == "positive"
                        portuguese ? "Relatos recentes mais favoráveis para este local." : "Recent reports are more favorable for this place."
                      elsif status_key == "negative"
                        portuguese ? "Vale revisar os relatos antes de seguir." : "Worth reviewing recent reports before going."
                      else
                        portuguese ? "Ainda não há sinal suficiente para decidir com segurança." : "There is not enough signal yet for a confident decision."
                      end %>
                </p>

                <%= link_to(
                      portuguese ? "Ver detalhes" : "View details",
                      place_path(place, detail_params),
                      class: "btn-details"
                    ) %>
              </div>
            </article>
          <% end %>
        <% else %>
          <div class="place-card place-card-empty">
            <div class="place-card-header">
              <h2>
                <%= if search_active
                      portuguese ? "Nenhum resultado encontrado" : "No results found"
                    else
                      portuguese ? "Nenhum local disponível" : "No places available"
                    end %>
              </h2>
            </div>

            <p class="place-address">
              <%= if search_active
                    portuguese ? "Tente buscar por outro nome ou endereço." : "Try searching for a different name or address."
                  else
                    portuguese ? "Volte mais tarde para conferir novos locais." : "Check back later for new places."
                  end %>
            </p>

            <%= link_to(
                  search_active ? (portuguese ? "Ver todos os locais" : "View all places") : (portuguese ? "Atualizar lista" : "Refresh list"),
                  places_path,
                  class: "btn-details"
                ) %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="map-column">
      <div class="map-panel">
        <div class="map-panel-header">
          <div>
            <span class="places-eyebrow"><%= portuguese ? "Mapa ao vivo" : "Live map" %></span>
            <h2><%= portuguese ? "Compare locais visualmente" : "Compare places visually" %></h2>
          </div>

          <p><%= portuguese ? "Clique em um card para focar no mapa ou use o botão de localização." : "Click a card to focus the map or use the location button." %></p>
        </div>

        <div class="map-wrapper">
          <div id="map"></div>
          <button class="geolocate-button" data-map-target="geolocateBtn" data-action="click->map#geolocate">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="34" height="34" filter="drop-shadow(0 2px 4px rgba(0,0,0,0.35))">
              <path fill="#f59e0b" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/>
            </svg>
          </button>

          <div hidden>
            <% @map_places.each do |place| %>
              <div data-map-target="popup" data-place-id="<%= place.id %>">
                <%= render "places/popup", place: place %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
