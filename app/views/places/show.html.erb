<% query = params[:query].to_s.strip %>
<% portuguese = I18n.locale.to_s == "pt-BR" %>
<% back_label =
     if query.present?
       portuguese ? "← Voltar aos resultados" : "← Back to results"
     else
       portuguese ? "← Voltar para o mapa" : "← Back to map"
     end %>
<% category_options =
     if portuguese
       ["Ambiente", "Segurança", "Preconceito", "Assédio", "Violência", "Outros"]
     else
       ["Environment", "Safety", "Discrimination", "Harassment", "Violence", "Other"]
     end %>
<% status_options =
     if portuguese
       [["Positivo", "positive"], ["Negativo", "negative"]]
     else
       [["Positive", "positive"], ["Negative", "negative"]]
     end %>
<% status_key = @place.status %>
<% status_label =
     case status_key
     when "positive" then (portuguese ? "Seguro" : "Safe")
     when "negative" then (portuguese ? "Evitar" : "Avoid")
     else
       portuguese ? "Atenção" : "Attention"
     end %>
<% positive_count = @reports.count { |report| report.status == "positive" } %>
<% negative_count = @reports.count { |report| report.status == "negative" } %>
<% latest_report = @reports.max_by(&:created_at) %>
<% latest_report_label =
     if latest_report.present?
       portuguese ? latest_report.created_at.strftime("%d/%m/%Y") : latest_report.created_at.strftime("%b %d, %Y")
     else
       "—"
     end %>

<div class="place-detail-page">
  <div class="container">
    <div class="place-detail-shell">
      <%= link_to(
            back_label,
            query.present? ? places_path(query: query) : places_path,
            class: "place-detail-back"
          ) %>

      <section class="place-detail-hero place-detail-hero--<%= status_key %>">
        <div class="place-hero-copy">
          <div class="place-status-badge place-status-badge--<%= status_key %>">
            <span class="place-status-dot"></span>
            <span><%= status_label %></span>
          </div>

          <h1><%= @place.name %></h1>
          <p class="place-hero-address"><%= @place.address %></p>

          <p class="place-hero-summary">
            <%= if portuguese
                  "Veja a leitura atual do local, o histórico recente de relatos da comunidade e adicione contexto novo quando necessário."
                else
                  "Review the current read of this place, recent community reports, and add fresh context when needed."
                end %>
          </p>
        </div>

        <div class="place-hero-metrics">
          <div class="place-hero-metric">
            <strong><%= @reports.size %></strong>
            <span><%= portuguese ? "relatos totais" : "total reports" %></span>
          </div>

          <div class="place-hero-metric">
            <strong><%= positive_count %></strong>
            <span><%= portuguese ? "positivos" : "positive" %></span>
          </div>

          <div class="place-hero-metric">
            <strong><%= negative_count %></strong>
            <span><%= portuguese ? "negativos" : "negative" %></span>
          </div>

          <div class="place-hero-metric">
            <strong>
              <%= latest_report_label %>
            </strong>
            <span><%= portuguese ? "última atualização" : "latest update" %></span>
          </div>
        </div>
      </section>

      <div class="place-detail-layout">
        <main class="place-detail-main">
          <section class="place-section-card">
            <div class="place-section-heading">
              <div>
                <span class="place-section-eyebrow"><%= portuguese ? "Leitura atual" : "Current read" %></span>
                <h2><%= portuguese ? "O que a comunidade está sinalizando" : "What the community is signaling" %></h2>
              </div>
            </div>

            <div class="place-signal-grid">
              <div class="place-signal-card place-signal-card--<%= status_key %>">
                <span class="signal-card-label"><%= portuguese ? "Status do lugar" : "Place status" %></span>
                <strong><%= status_label %></strong>
                <p>
                  <%= if status_key == "positive"
                        portuguese ? "Os relatos recentes tendem a ser mais favoráveis." : "Recent reports lean more favorable."
                      elsif status_key == "negative"
                        portuguese ? "Os relatos recentes indicam mais risco ou desconforto." : "Recent reports indicate more risk or discomfort."
                      else
                        portuguese ? "Ainda não há consenso suficiente nos relatos." : "There is not enough consensus in the reports yet."
                      end %>
                </p>
              </div>

              <div class="place-signal-card">
                <span class="signal-card-label"><%= portuguese ? "Endereço" : "Address" %></span>
                <strong><%= @place.address %></strong>
                <p><%= portuguese ? "Confirme se este é exatamente o local que você quer revisar." : "Confirm this is exactly the location you want to review." %></p>
              </div>
            </div>
          </section>

          <section class="place-section-card">
            <div class="place-section-heading">
              <div>
                <span class="place-section-eyebrow"><%= portuguese ? "Relatos" : "Reports" %></span>
                <h2><%= portuguese ? "Histórico recente da comunidade" : "Recent community history" %></h2>
              </div>
              <span class="place-section-count"><%= @reports.size %></span>
            </div>

            <% if @reports.empty? %>
              <div class="place-empty-state">
                <h3><%= portuguese ? "Ainda não há relatos" : "No reports yet" %></h3>
                <p><%= portuguese ? "Se você conhece este local, adicione o primeiro relato para ajudar a próxima pessoa a decidir melhor." : "If you know this place, add the first report to help the next person decide better." %></p>
              </div>
            <% else %>
              <div class="place-reports-list">
                <% @reports.order(created_at: :desc).each do |report| %>
                  <% report_status_label =
                       if report.status == "positive"
                         portuguese ? "Positivo" : "Positive"
                       else
                         portuguese ? "Negativo" : "Negative"
                       end %>
                  <% report_time_label = portuguese ? report.created_at.strftime("%d/%m/%Y • %H:%M") : report.created_at.strftime("%b %d, %Y • %H:%M") %>

                  <article class="report-card report-card--<%= report.status %>">
                    <div class="report-card-top">
                      <div class="report-card-meta">
                        <span class="report-category"><%= report.category %></span>
                        <span class="report-status report-status--<%= report.status %>"><%= report_status_label %></span>
                      </div>
                      <span class="report-time"><%= report_time_label %></span>
                    </div>

                    <p class="report-description"><%= report.description %></p>

                    <p class="report-author"><%= report.user.email %></p>
                  </article>
                <% end %>
              </div>
            <% end %>
          </section>
        </main>

        <aside class="place-detail-sidebar">
          <div class="place-action-card">
            <span class="place-section-eyebrow">Contribuição da comunidade</span>
            <h2>Adicionar um relato</h2>
            <p>
              Compartilhe um contexto recente e ajude outras pessoas a decidir com mais segurança antes de sair.
            </p>

            <% if user_signed_in? %>
              <%= form_with model: [@place, @review], local: true, class: "place-report-form" do |f| %>
                <% if @review.errors.any? %>
                  <div class="place-form-errors">
                    <p><strong>Não foi possível enviar seu relato.</strong></p>
                    <p><%= @review.errors.full_messages.to_sentence %></p>
                  </div>
                <% end %>

                <div class="place-form-section">
                  <div class="place-form-section__header">
                    <span class="place-form-section__step">1</span>
                    <div>
                      <h3>Classifique o local</h3>
                      <p>Escolha o tipo de relato e o sinal mais adequado para este momento.</p>
                    </div>
                  </div>

                  <div class="place-form-grid">
                    <div class="place-form-group">
                      <%= f.label :category, "Categoria do relato" %>
                      <span class="place-form-help">Ex.: segurança, assédio, furto, ambiente, atendimento.</span>
                      <%= f.select :category, review_category_options, {}, class: "place-form-control" %>
                    </div>

                    <div class="place-form-group">
                      <%= f.label :status, "Sinal do local" %>
                      <span class="place-form-help">Selecione como este local deve ser interpretado agora.</span>

                      <div class="place-status-selector">
                        <label class="place-status-option place-status-option--positive">
                          <%= f.radio_button :status, "positive" %>
                          <span>🟢 Seguro</span>
                        </label>

                        <label class="place-status-option place-status-option--negative">
                          <%= f.radio_button :status, "negative" %>
                          <span>🔴 Evitar</span>
                        </label>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="place-form-section">
                  <div class="place-form-section__header">
                    <span class="place-form-section__step">2</span>
                    <div>
                      <h3>Conte o contexto</h3>
                      <p>Seja específico. Relatos objetivos ajudam mais do que comentários genéricos.</p>
                    </div>
                  </div>

                  <div class="place-form-group">
                    <%= f.label :description, "Descrição" %>
                    <span class="place-form-help">Explique o que aconteceu, quando aconteceu e o que outras pessoas devem observar.</span>
                    <%= f.text_area :description, rows: 6, class: "place-form-control place-form-control--textarea", placeholder: "Ex.: Fui ao local ontem à noite, a entrada estava vazia, houve confusão na saída e faltava presença de segurança..." %>
                  </div>
                </div>

                <div class="place-form-footer">
                  <p class="place-form-note">
                    Seu relato ajuda a construir um mapa mais útil, visual e confiável para toda a comunidade.
                  </p>
                  <%= f.submit "Publicar relato", class: "place-submit-button" %>
                </div>
              <% end %>
            <% else %>
              <div class="place-signin-card">
                <p>Faça login para compartilhar um relato e contribuir com o mapa da comunidade.</p>
                <%= link_to "Entrar para contribuir", new_user_session_path, class: "place-submit-button" %>
              </div>
            <% end %>
          </div>
        </aside>
      </div>
    </div>
  </div>
</div>
