<nav class="main-navbar"
     data-controller="navbar"
     data-action="resize@window->navbar#handleResize">
  <div class="container">
    <div class="navbar-content">

      <!-- LEFT: BRAND -->
      <div class="navbar-left">
        <%= link_to root_path, class: "navbar-brand" do %>
          <%= image_tag "before_you_go.png", class: "navbar-logo" %>
        <% end %>
      </div>

      <!-- RIGHT: NAV LINKS -->
      <div class="navbar-right">

        <div class="navbar-primary-links">
          <%= link_to t("nav.home"), root_path, class: "navbar-link" %>

          <% if user_signed_in? %>

            <div class="navbar-dropdown">
              <span class="navbar-link navbar-link-outline">
                <%= current_user.display_name %>
              </span>

              <div class="dropdown-menu-custom">
                <%= link_to "Reviews", root_path(locale: I18n.locale, open_reviews: "1"), class: "dropdown-item-custom" %>
                <%= link_to "Logout",
                  destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "dropdown-item-custom" %>
              </div>
            </div>

          <% else %>

            <%= link_to "Login", new_user_session_path, class: "navbar-link navbar-link-outline" %>

            <%= link_to "Get started", new_user_registration_path, class: "navbar-link navbar-link-primary" %>

          <% end %>
        </div>

        <div class="navbar-language-switcher" aria-label="Language switcher">
          <%= link_to "EN", url_for(locale: :en), class: "navbar-link navbar-link-language" %>
          <%= link_to "PT", url_for(locale: :"pt-BR"), class: "navbar-link navbar-link-language" %>
        </div>

      </div>
    </div>
  </div>
</nav>
