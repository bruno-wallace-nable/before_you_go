<div class="map-popup-card map-popup-card--<%= place.status %>">
  <div class="map-popup-card__header">
    <div>
      <h3 class="map-popup-card__title"><%= place.name %></h3>
      <p class="map-popup-card__address"><%= place.address %></p>
    </div>

    <span class="map-popup-card__badge map-popup-card__badge--<%= place.status %>">
      <%= place.status_label %>
    </span>
  </div>

  <% if place.reports.empty? %>
    <div class="map-popup-card__empty">
      <p class="map-popup-card__empty-title">Ainda não há relatos</p>
      <p class="map-popup-card__empty-text">
        Seja a primeira pessoa a adicionar contexto para este local.
      </p>
    </div>
  <% else %>
    <div class="map-popup-card__reports">
      <% place.reports.limit(2).each do |report| %>
        <article class="map-popup-report map-popup-report--<%= report.status %>">
          <div class="map-popup-report__top">
            <span class="map-popup-report__category"><%= report.category %></span>
            <span class="map-popup-report__status map-popup-report__status--<%= report.status %>">
              <%= report.status == "positive" ? "Positivo" : "Negativo" %>
            </span>
          </div>

          <p class="map-popup-report__description"><%= truncate(report.description, length: 110) %></p>
        </article>
      <% end %>

      <% if place.reports.count > 2 %>
        <p class="map-popup-card__more">
          +<%= place.reports.count - 2 %> relatos
        </p>
      <% end %>
    </div>
  <% end %>

  <div class="map-popup-card__footer">
    <%= link_to "Ver detalhes", place_path(place), class: "map-popup-card__button" %>
  </div>
</div>
