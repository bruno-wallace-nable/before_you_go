<% query = params[:query].to_s.strip %>
<% portuguese = I18n.locale.to_s == "pt-BR" %>
<% back_label =
     if query.present?
       portuguese ? "← Voltar aos resultados" : "← Back to results"
     else
       portuguese ? "← Voltar para o mapa" : "← Back to map"
     end %>
<% category_options =
     if portuguese
       ["Ambiente", "Segurança", "Preconceito", "Assédio", "Violência", "Outros"]
     else
       ["Environment", "Safety", "Discrimination", "Harassment", "Violence", "Other"]
     end %>
<% status_options =
     if portuguese
       [["Positivo", "positive"], ["Negativo", "negative"]]
     else
       [["Positive", "positive"], ["Negative", "negative"]]
     end %>

<%= link_to(
      back_label,
      query.present? ? places_path(query: query) : places_path
    ) %>

<h1><%= @place.name %></h1>
<p><%= @place.address %></p>
<p><%= portuguese ? "Status:" : "Status:" %> <%= @place.status_label %></p>

<h2><%= portuguese ? "Relatos" : "Reports" %></h2>

<% if @reports.empty? %>
  <p><%= portuguese ? "Ainda não há relatos." : "No reports yet." %></p>
<% else %>
  <% @reports.each do |report| %>
    <div>
      <p>
        <strong><%= report.category %></strong>
        —
        <%= if report.status == "positive"
              portuguese ? "Positivo" : "Positive"
            elsif report.status == "negative"
              portuguese ? "Negativo" : "Negative"
            else
              report.status
            end %>
      </p>
      <p><%= report.description %></p>
      <p><small><%= report.user.email %></small></p>
    </div>
  <% end %>
<% end %>

<h2><%= portuguese ? "Adicionar relato" : "Add a report" %></h2>

<% if user_signed_in? %>
  <%= form_with model: @report, url: place_reports_path(@place) do |f| %>
    <% if @report.errors.any? %>
      <div>
        <% @report.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :category, (portuguese ? "Categoria" : "Category") %>
      <%= f.select :category, category_options %>
    </div>

    <div>
      <%= f.label :status, (portuguese ? "Status" : "Status") %>
      <%= f.select :status, status_options %>
    </div>

    <div>
      <%= f.label :description, (portuguese ? "Descrição" : "Description") %>
      <%= f.text_area :description %>
    </div>

    <%= f.submit(portuguese ? "Enviar relato" : "Submit report") %>
  <% end %>
<% else %>
  <p>
    <%= link_to(portuguese ? "Entrar" : "Sign in", new_user_session_path) %>
    <%= portuguese ? " para adicionar um relato." : " to add a report." %>
  </p>
<% end %>
